{
  "name": "ai-staffing-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter @ai-staffing-os/api --filter @ai-staffing-os/web run dev",
    "build": "pnpm --recursive run build",
    "typecheck": "pnpm --recursive run typecheck",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test",
    "db:generate": "pnpm --filter @ai-staffing-os/db run generate",
    "db:migrate": "pnpm --filter @ai-staffing-os/db run migrate",
    "db:seed": "pnpm --filter @ai-staffing-os/db run seed",
    "db:studio": "pnpm --filter @ai-staffing-os/db run studio"
  },
  "devDependencies": {
    "eslint": "^9.11.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript-eslint": "^8.8.0"
  }
}
