
# F12.2: referencia completa de cada variable en docs/ENVIRONMENT_VARIABLES.md
# -- este archivo es la plantilla ejecutable, ese documento es la
# explicación de qué hace cada una y cuándo es obligatoria. La única
# variable realmente requerida (falla el arranque sin ella) es
# DATABASE_URL -- el resto tiene default seguro o se degrada
# honestamente si falta.

DATABASE_URL="postgresql://staffing:staffing@localhost:5433/ai_staffing_os"
PORT=4000
NODE_ENV=development
AUTH_MODE=dev-bypass
OPENAI_API_KEY=

# F4.9-D1: usuario que usa DevBypassAuthProvider cuando el request no
# manda x-dev-user. Solo-dev, nunca auth real — ver
# apps/api/src/modules/auth/dev-bypass.provider.ts.
DEV_DEFAULT_USER_EMAIL=admin@titan.dev

# F4.9: Clerk (proveedor de autenticación de producción). El código ya
# existe (modules/auth/clerk.provider.ts) pero queda inactivo mientras
# AUTH_MODE=dev-bypass. AUTH_MODE=production exige que estas 2 primeras
# estén configuradas (env.ts falla el arranque si no) — ver
# docs/F4_9_PRODUCTION_AUTH_PLAN.md y
# docs/F12_PRODUCTION_READINESS_BASELINE.md §3.5 (bloqueo real: no hay
# una aplicación Clerk real conectada en este entorno).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_SIGN_IN_URL=/sign-in
CLERK_SIGN_UP_URL=/sign-up
CLERK_AFTER_SIGN_IN_URL=/
CLERK_AFTER_SIGN_UP_URL=/

# F4.9: allowlist de CORS — en Render, sobreescribir con las URLs reales
# del servicio (ej. https://ai-staffing-os-web.onrender.com) desde el
# dashboard de env vars, nunca hardcodeado acá.
APP_ORIGIN=http://localhost:5173
MARKETING_ORIGIN=http://localhost:5174
API_ORIGIN=http://localhost:4000

# F4.9-D5: URL absoluta del API para el frontend cuando NO comparte
# origen (Render, con apps/web y apps/api como servicios separados).
# Vacío = usa la ruta relativa /api/v1 (dev local, vía proxy de Vite).
VITE_API_URL=

# F4.9: frontend (Vite expone solo variables con prefijo VITE_) — mismo
# estado diferido que el resto de CLERK_* arriba. Nunca la clave
# secreta acá — Vite solo empaqueta variables VITE_*, CLERK_SECRET_KEY
# nunca debe tener ese prefijo.
VITE_CLERK_PUBLISHABLE_KEY=

# F4.5/F4.6/F4.7: proveedores comerciales opcionales de los agentes de
# discovery/contacto/email — cada uno se degrada honestamente sin
# inventar datos si falta (ver docs/ENVIRONMENT_VARIABLES.md).
GOOGLE_PLACES_API_KEY=
PEOPLEDATALABS_API_KEY=
HUNTER_API_KEY=
WEBSITE_INTELLIGENCE_CONTACT_EMAIL=

# Branding — decisión real del PO (marca DreiStaff / dominio
# dreistaff.com, entidad legal Data More LLC). Ya tienen default real en
# env.ts; se listan acá solo para que quede explícito qué se puede
# override por entorno (ej. un dominio de staging distinto).
BUSINESS_LEGAL_NAME=Data More LLC
BUSINESS_BRAND_NAME=DreiStaff
BUSINESS_DOMAIN=dreistaff.com
APP_DOMAIN=app.dreistaff.com
OUTREACH_FROM_NAME=DreiStaff
# Deliberadamente vacíos — ningún código de outreach puede enviar un
# email real mientras falten (requisito legal CAN-SPAM antes de
# habilitar envío real).
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO=
BUSINESS_POSTAL_ADDRESS=

# F17: Microsoft Graph — envío real de email vía OAuth2 Client
# Credentials (app-only, nunca /me/sendMail). Las 3 deben ir juntas o
# ninguna (env.ts se niega a arrancar con una configuración parcial).
# El remitente COMERCIAL (Approval Requests/campañas/outreach/
# seguimiento de Leads y Opportunities) está hardcodeado a
# sales@<BUSINESS_DOMAIN> en modules/email/sender-profiles.ts — nunca
# configurable por env, para que nunca pueda usarse un remitente
# arbitrario. MAIL_FROM es solo el remitente GENERAL (contacto
# institucional/formularios públicos) y debe ser del propio
# BUSINESS_DOMAIN.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MAIL_FROM=

# F4.7.5: Production Mode — false permite datos demo/seed/regresión
# (estado de hoy en todo entorno). true prohíbe crear datos demo y
# bloquea seed.ts — decisión exclusiva del PO, para cuando la agencia
# empiece a operar con datos 100% reales. Ver core/production-mode.ts.
PRODUCTION_MODE=false

# F4.8: qué tenant sirve el sitio público (dreistaff.com).
PUBLIC_TENANT_SLUG=titan
