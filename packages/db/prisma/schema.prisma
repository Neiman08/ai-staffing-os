// =============================================================
// AI Staffing OS — Prisma Schema v1.0 (Fase 0)
// Basado en el Documento de Arquitectura v1.1 (aprobado)
//
// DECISIONES DE DISEÑO (no re-decidir en Claude Code):
// 1. tenantId es String indexado SIN @relation a Tenant.
//    El aislamiento se garantiza con Prisma Client Extension +
//    middleware de tenancy, no con FKs. Mantiene el modelo Tenant
//    limpio y evita ~30 back-relations.
// 2. Referencias de actor ("quién lo hizo": approvedById, ownerId,
//    decidedById, verifiedById) son String? sin @relation, validadas
//    en la capa de servicios. Relaciones reales solo para estructura
//    de dominio.
// 3. Dinero y tarifas: siempre Decimal, nunca Float.
// 4. Todo lo configurable es data: Industry, JobCategory,
//    DocumentType, Role, Permission.
// 5. pgvector (AgentMemory.embedding) sigue diferido más allá de F3
//    (decisión reafirmada en F3_PROSPECTING_ENGINE_PLAN.md §7 — la
//    memoria de F3 usa AgentMemory sin embeddings). No requerir la
//    extensión todavía.
// 6. Daily Revenue Mission (F4) NO tiene modelo propio — es un AgentTask
//    raíz (type: "daily_revenue_mission") con parentTaskId plano hacia
//    sus tareas delegadas. Objetivo/filtros/businessObjective viven en
//    input; progreso/objectiveProgress/Executive Report viven en output.
//    Ver F4_AUTONOMOUS_OUTREACH_PLAN.md, addendum "Daily Revenue Mission".
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUMS =================

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum CompanyStatus {
  LEAD
  PROSPECT
  CLIENT
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

// F1: reemplaza DISCOVERY/PROPOSAL por las etapas del pipeline de 8 columnas
// (Decisión CHECKPOINT F1 §2.4, Opción A). Opportunity no tenía filas en F0,
// así que este cambio de valores es seguro sin backfill.
enum OpportunityStage {
  MEETING_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum CompanySize {
  MICRO // 1-10
  SMALL // 11-50
  MEDIUM // 51-200
  LARGE // 201-1000
  ENTERPRISE // 1000+
}

enum ContactDecisionRole {
  OWNER
  HR
  OPERATIONS_MANAGER
  PROJECT_MANAGER
  PLANT_MANAGER
  RECRUITER
  OTHER
  // F4.6: cargos prioritarios del Contact Intelligence Agent — el título
  // real siempre vive en Contact.title (texto libre, literal de la
  // fuente); este enum solo categoriza para filtrar en la UI.
  TALENT_ACQUISITION
  WAREHOUSE_MANAGER
  GENERAL_MANAGER
  PURCHASING_MANAGER
  DIRECTOR_OF_OPERATIONS
}

enum FollowUpType {
  CALL
  EMAIL
  LINKEDIN
  MEETING
}

enum FollowUpStatus {
  PENDING
  DONE
  SNOOZED
  CANCELLED
}

// F4
enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

// F4
enum CampaignCompanyStatus {
  TARGETED // seleccionada, secuencia todavía no arrancó
  SEQUENCING // secuencia en curso, sin respuesta clasificada todavía
  HOT // última intención: interesado / muy interesado / llamar después
  COLD // secuencia terminada sin respuesta, o intención negativa
  RECOVERED // estaba COLD y volvió a mostrar intención positiva
  CONVERTED // el Lead asociado llegó a CONVERTED / la Company a CLIENT
  EXCLUDED // sacada manualmente de la campaña por un humano
}

// F4
enum ConversationIntent {
  INTERESTED
  VERY_INTERESTED
  CALL_LATER
  NO_BUDGET
  HAS_PROVIDER
  NOT_INTERESTED
  OUT_OF_MARKET
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
  SYSTEM
}

enum CandidateStatus {
  NEW
  SCREENING
  QUALIFIED
  PLACED
  REJECTED
  INACTIVE
}

// F8.5: estado persistido de la evaluación de reglas de F8.2
// (recruiting-intelligence/qualification-rules.ts) para un par
// Candidate+JobOrder específico -- deliberadamente distinto de
// CandidateStatus (ciclo de vida general del candidato, no por Job Order).
enum QualificationStatus {
  QUALIFIED
  POSSIBLY_QUALIFIED
  NEEDS_REVIEW
  NOT_QUALIFIED
}

enum EmploymentType {
  W2
  C1099
}

enum WorkerStatus {
  AVAILABLE
  ASSIGNED
  ON_LEAVE
  TERMINATED
}

enum ComplianceStatus {
  COMPLIANT
  PENDING
  BLOCKED
}

// F5.1: DRAFT agregado — un Job Order recién creado desde la UI arranca
// acá, nunca directamente en OPEN (no debe considerarse activo ni
// disponible para Assignments mientras esté en DRAFT). Pasar a OPEN es
// una acción explícita y auditable (PATCH /job-orders/:id/status), nunca
// automática. ON_HOLD queda deliberadamente fuera — decisión explícita
// del PO (2026-07-13), se evalúa como cambio independiente cuando exista
// un caso operativo real; CANCELLED nunca debe usarse como sustituto.
enum JobOrderStatus {
  DRAFT
  OPEN
  PARTIALLY_FILLED
  FILLED
  CLOSED
  CANCELLED
}

enum ShiftType {
  DAY
  NIGHT
  WEEKEND
  ROTATING
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum TimeEntryStatus {
  PENDING
  APPROVED
  LOCKED
}

enum TimeEntrySource {
  MANUAL
  TIMECLOCK
  IMPORT
}

enum DocumentStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum ComplianceAlertType {
  EXPIRING
  EXPIRED
  MISSING
  FAILED_CHECK
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PayrollRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  EXPORTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AutonomyLevel {
  MANUAL
  ASSISTED
  SEMI_AUTO
  AUTO_WITH_APPROVAL
  FULL_AUTO
}

enum AgentTaskStatus {
  QUEUED
  RUNNING
  AWAITING_APPROVAL
  DONE
  FAILED
}

enum TaskTrigger {
  USER
  EVENT
  AGENT
  SCHEDULE
}

enum MemoryScope {
  GLOBAL
  ENTITY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ActorType {
  HUMAN
  AGENT
  SYSTEM
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum BenchmarkSource {
  INTERNAL_PLACEMENTS
  BLS_OES
  JOB_BOARDS
  MANUAL
}

enum PricingScenarioStatus {
  DRAFT
  PRESENTED
  ACCEPTED
  REJECTED
}

enum HiringRisk {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  INFO
  ALERT
  APPROVAL
  AGENT_ACTIVITY
}

// ================= NÚCLEO Y TENANCY =================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STARTER)
  settings  Json     @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // F4.9: mapeo Tenant ↔ Clerk Organization. null hasta que se cree/vincule
  // la organización real en Clerk (ver docs/F4_9_PRODUCTION_AUTH_PLAN.md
  // §4.3) — ClerkAuthProvider resuelve tenantId ÚNICAMENTE por acá, nunca
  // por un header o dato enviado por el cliente.
  clerkOrganizationId String? @unique
}

// F4.9: estado del flujo de invitación de un User frente a Clerk — NOT_INVITED
// es el default honesto para todo usuario que nunca pasó por invitación
// (ej. los usuarios seed, creados directo en DB). PENDING se setea al invitar
// (POST /auth/users/invite); ACCEPTED cuando el webhook user.created encuentra
// esa invitación; REVOKED/EXPIRED reflejan el estado equivalente en Clerk.
enum InvitationStatus {
  NOT_INVITED
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  clerkId   String?  @unique // null en modo dev-bypass
  email     String
  firstName String
  lastName  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // F4.9: espejo de lectura de Clerk — Clerk sigue siendo la fuente de
  // verdad real de identidad/sesión/MFA (ver docs/F4_9_PRODUCTION_AUTH_PLAN.md
  // §1), estas columnas solo evitan una llamada a Clerk en cada render de
  // la UI de Users & Roles. Se sincronizan vía webhook (user.updated) y en
  // ClerkAuthProvider.resolveIdentity (lastLoginAt).
  lastLoginAt      DateTime?
  mfaEnabled       Boolean           @default(false)
  invitationStatus InvitationStatus  @default(NOT_INVITED)

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String
  name        String // CEO, Admin, Recruiter, Sales, Payroll, Compliance, Operations, Marketing, HR, Accounting, Manager
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique // formato "recurso.accion", ej: "candidates.create"
  label String
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ================= CRM =================

model Industry {
  id         String        @id @default(cuid())
  tenantId   String? // null = industria global (seed)
  name       String
  isGlobal   Boolean       @default(false)
  companies  Company[]
  categories JobCategory[]
  leads      Lead[] // F1
  campaigns  Campaign[] // F4

  @@index([tenantId])
}

// F4.5: procedencia de una Company — nunca debe haber duda entre una
// empresa de demo, importada, creada a mano, o descubierta externamente.
enum CompanyOrigin {
  DEMO_SEED
  MANUAL
  CSV_IMPORT
  EXTERNAL_DISCOVERY
  API_PROVIDER
}

// F4.5: UNVERIFIED es el default honesto para todo lo previo a F4.5 (nadie
// corrió una verificación externa sobre esos registros) — CONFIRMED/
// INFERRED solo se usan cuando una fuente externa real respaldó el dato.
enum CompanyVerificationStatus {
  UNVERIFIED
  CONFIRMED
  INFERRED
}

model Company {
  id                      String                    @id @default(cuid())
  tenantId                String
  name                    String
  industryId              String
  industry                Industry                  @relation(fields: [industryId], references: [id])
  status                  CompanyStatus             @default(LEAD)
  website                 String?
  phone                   String?
  email                   String? // F4.5: correo público general de la empresa (distinto del email personal de un Contact)
  address                 Json? // { street, zip } — city/state promovidos a columnas (F1)
  city                    String? // F1: promovido de address.city para agregaciones (Revenue Intelligence)
  state                   String? // F1: promovido de address.state
  estimatedSize           CompanySize? // F1
  possibleCategories      JobCategory[]             @relation("CompanyPossibleCategories") // F1: "necesidades posibles"
  commercialScore         Float? // F1: score comercial a nivel empresa
  commercialScoreReason   String? // F2: explicación auditable del score (Sales Agent, ver F2 §7)
  notes                   String?
  // F4.5: transparencia de origen — ver docs/F4_AUTONOMOUS_OUTREACH_PLAN.md
  // addendum "Transparencia de origen de empresas".
  origin                  CompanyOrigin             @default(MANUAL)
  sourceUrl               String? // solo EXTERNAL_DISCOVERY/API_PROVIDER — permalink de la fuente real
  discoveredAt            DateTime?
  discoveredByAgentTaskId String? // sin @relation, mismo patrón que createdByAgentTaskId
  verificationStatus      CompanyVerificationStatus @default(UNVERIFIED)
  confidenceScore         Float? // 0–1, solo cuando verificationStatus != UNVERIFIED
  lastVerifiedAt          DateTime?
  // Evidencia estructurada del descubrimiento/clasificación de esta
  // Company — nunca reemplaza industryId (FK real, sigue siendo la
  // fuente de verdad de la industria). Estructura versionada
  // (schemaVersion), generada exclusivamente en backend, nunca se
  // confía en un valor enviado por el frontend. Shape: { schemaVersion,
  // searchTermsMatched: string[], providerBusinessTypes: string[],
  // detectedBusinessType, detectedSector, crmIndustryId, crmIndustryName,
  // classificationMode: "EXACT"|"APPROXIMATE"|"FALLBACK"|"UNCLASSIFIED",
  // classificationConfidence, classificationReason, providerPlaceId,
  // canonicalDomain, originalWebsite, canonicalWebsite, originalPhone,
  // normalizedPhone, discoveredAt, lastUpdatedAt — ver
  // docs/ILLINOIS_COMPANY_BACKFILL_PLAN.md §5 y §14.
  discoveryMetadata       Json?
  contacts                Contact[]
  contactPoints           CompanyContactPoint[]
  leads                   Lead[]
  opportunities           Opportunity[]
  jobOrders               JobOrder[]
  projects                Project[]
  contracts               Contract[]
  invoices                Invoice[]
  campaignCompanies       CampaignCompany[] // F4
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, state])
  @@index([tenantId, origin])
}

// F4.6: mismo espíritu que CompanyVerificationStatus — UNVERIFIED es el
// default honesto para contactos previos al Contact Intelligence Agent;
// CONFIRMED/INFERRED solo cuando una fuente externa real respaldó el
// dato. Enum separado (no se reutiliza CompanyVerificationStatus) para
// no confundir a quien lea el schema sobre a qué modelo aplica.
enum ContactVerificationStatus {
  UNVERIFIED
  CONFIRMED
  INFERRED
}

// F4.7: estado de ENTREGABILIDAD del email, distinto de
// ContactVerificationStatus (que describe la procedencia del contacto
// como registro completo). Vocabulario cerrado — solo VERIFIED puede
// habilitar outreach real, ver docs/F4_7_EMAIL_INTELLIGENCE_PLAN.md §3.
enum EmailVerificationStatus {
  NOT_VERIFIED
  VERIFIED
  RISKY
  INVALID
  UNKNOWN
}

model Contact {
  id                      String                    @id @default(cuid())
  tenantId                String
  companyId               String
  company                 Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  title                   String?
  linkedinUrl             String? // F1
  decisionRole            ContactDecisionRole? // F1: distinto de `title` (texto libre) — rol categorizado para targeting comercial
  isPrimary               Boolean                   @default(false)
  // F4.6: transparencia de procedencia — mismo principio que Company
  // desde F4.5 ("nunca inventar", "no disponible" si falta el dato).
  source                  String? // nombre del proveedor real (ej. "People Data Labs") o null si es manual/import
  confidenceScore         Float?
  discoveredAt            DateTime?
  discoveredByAgentTaskId String?
  verificationStatus      ContactVerificationStatus @default(UNVERIFIED)
  // F4.7: procedencia y verificación del EMAIL específicamente — un
  // Contact puede venir de un proveedor (source) pero tener el email
  // encontrado/verificado después, por una fuente distinta (Website
  // Intelligence o Hunter). Ver docs/F4_7_EMAIL_INTELLIGENCE_PLAN.md §4.
  emailSource               String? // "Website (about/team page)" | "Hunter.io" | null
  emailSourceUrl            String? // URL exacta de la página, o referencia del proveedor
  emailDiscoveryProvider    String?
  emailVerificationProvider String?
  emailVerificationStatus   EmailVerificationStatus  @default(NOT_VERIFIED)
  emailConfidenceScore      Float? // 0–1, del proveedor de verificación — distinto de confidenceScore (descubrimiento del contacto)
  emailDiscoveredAt         DateTime?
  emailVerifiedAt           DateTime?
  // F4.7: control de envío — por dirección/persona, no por Company.
  doNotContact              Boolean                  @default(false)
  bouncedAt                 DateTime?
  unsubscribedAt            DateTime?
  createdAt               DateTime                  @default(now())
  // F7.8: Contact Verification and Ranking — determinista (contact-ranking.ts),
  // nunca decidido por un LLM. Null cuando el Contact no pasó todavía por
  // el ranking (ej. contactos creados antes de F7.8, o por otra vía).
  rankingTier             ContactRankingTier?
  rankingScore            Float?
  rankingReasons          String[]                  @default([])
  rankedAt                DateTime?

  @@index([tenantId])
  @@index([companyId])
  @@index([tenantId, emailVerificationStatus])
  @@index([tenantId, rankingTier])
}

// F7.8: espeja literalmente ContactRankingTier de
// apps/api/.../ceo-intelligence/contact-ranking.ts (mismo criterio de
// "mirror the shape" ya establecido para EmailTrustOutcome).
enum ContactRankingTier {
  HIGH_CONFIDENCE
  MEDIUM_CONFIDENCE
  LOW_CONFIDENCE
  REJECTED
}

// Tipo de punto de contacto organizacional — nunca un nombre de
// persona. Vocabulario cerrado, aprobado por el PO.
enum CompanyContactPointType {
  INFO
  SALES
  HR
  RECRUITING
  CAREERS
  SUPPORT
  PRESS
  BILLING
  PROCUREMENT
  OTHER
}

// Representa honestamente un punto de contacto público de la empresa
// (info@, sales@, hr@...) que NO tiene un dueño
// humano identificado — nunca se convierte en Contact, nunca se le
// asigna un nombre inventado. Mismo nivel de trazabilidad que Contact ya
// tiene para personas (fuente, proveedor, verificación, confianza), pero
// en un modelo separado para no contaminar "Contact = persona real".
model CompanyContactPoint {
  id                   String                  @id @default(cuid())
  tenantId             String
  companyId            String
  company              Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Siempre ya normalizado (trim + decodeURIComponent seguro + lowercase
  // + validado) antes de llegar acá — la normalización vive en el
  // servicio, nunca en este modelo.
  email                String
  type                 CompanyContactPointType @default(OTHER)
  sourceUrl            String? // URL exacta de la página que lo reveló — obligatorio en la práctica cuando discoveryProvider = "Website Intelligence" (verificado en servicio, no en schema)
  discoveryProvider    String? // "Website Intelligence" | "Hunter.io" | null si es manual
  verificationProvider String?
  // Reutiliza el enum ya existente de Contact.emailVerificationStatus —
  // mismo vocabulario, mismo significado (INVALID nunca disponible para
  // outreach, VERIFIED es el único estado que algún día lo habilitaría,
  // RISKY/UNKNOWN quedan visibles pero no disponibles) — no se inventa
  // un enum paralelo para el mismo concepto.
  verificationStatus   EmailVerificationStatus @default(NOT_VERIFIED)
  confidenceScore      Float?
  discoveredAt         DateTime?
  verifiedAt           DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  // Dedup por empresa+email normalizado — misma empresa puede tener
  // varios puntos de contacto (info@ Y sales@ a la vez), pero nunca el
  // mismo email dos veces.
  @@unique([companyId, email])
  @@index([tenantId])
  @@index([tenantId, verificationStatus])
}

model Lead {
  id                   String     @id @default(cuid())
  tenantId             String
  companyId            String?
  company              Company?   @relation(fields: [companyId], references: [id])
  industryId           String? // F1: un lead puede existir antes de tener Company
  industry             Industry?  @relation(fields: [industryId], references: [id])
  city                 String? // F1
  state                String? // F1
  priority             RiskLevel  @default(MEDIUM) // F1: reutiliza RiskLevel, ver F1_REVENUE_ENGINE_PLAN §2.3
  source               String? // referral, web, cold-outreach, indeed...
  status               LeadStatus @default(NEW)
  ownerId              String? // User.id (sin relation, ver decisión #2)
  aiScore              Float?
  aiScoreReason        String?
  createdByAgentTaskId String? // F2: mismo patrón que PricingScenario.createdByAgentTaskId
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, industryId])
}

model Opportunity {
  id                   String            @id @default(cuid())
  tenantId             String
  companyId            String
  company              Company           @relation(fields: [companyId], references: [id])
  title                String
  stage                OpportunityStage  @default(MEETING_SCHEDULED)
  categoryId           String? // F1: "tipo de trabajadores"
  category             JobCategory?      @relation(fields: [categoryId], references: [id])
  estimatedWorkers     Int?
  estimatedPayRate     Decimal?          @db.Decimal(10, 2) // F1
  estimatedBillRate    Decimal?          @db.Decimal(10, 2) // F1
  estimatedRevenue     Decimal?          @db.Decimal(12, 2)
  probability          Int? // 0-100
  expectedCloseDate    DateTime?
  ownerId              String?
  pricingScenarios     PricingScenario[]
  createdByAgentTaskId String? // F3: mismo patrón que Lead.createdByAgentTaskId (F2)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([tenantId, stage])
}

model Activity {
  id                 String       @id @default(cuid())
  tenantId           String
  type               ActivityType
  subject            String
  body               String?
  entityType         String // "company" | "candidate" | "jobOrder" | "lead" | "opportunity" | "contact" | ...
  entityId           String
  performedById      String? // User.id
  performedByAgentId String? // AgentInstance.id
  createdAt          DateTime     @default(now())

  @@index([tenantId, entityType, entityId])
}

// F1: sigue el mismo patrón polimórfico que Activity (entityType/entityId como
// strings, sin FK — decisión #2 del header: referencias de actor sin relation).
model FollowUp {
  id                   String         @id @default(cuid())
  tenantId             String
  entityType           String // "company" | "lead" | "opportunity" | "contact"
  entityId             String
  type                 FollowUpType
  dueDate              DateTime
  priority             RiskLevel      @default(MEDIUM)
  assignedToId         String? // User.id (sin relation, ver decisión #2)
  status               FollowUpStatus @default(PENDING)
  reminderAt           DateTime?
  notes                String?
  completedAt          DateTime?
  createdByAgentTaskId String? // F3: mismo patrón que Lead.createdByAgentTaskId (F2)
  campaignId           String? // F4: etiqueta un paso de secuencia de campaña — sin @relation, mismo patrón
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([tenantId, status, dueDate])
  @@index([tenantId, entityType, entityId])
}

// F4: ver F4_AUTONOMOUS_OUTREACH_PLAN.md §5-6. Campaign agrupa empresas
// objetivo bajo criterios de segmentación compartidos; CampaignCompany es
// la tabla de unión que registra el estado de una empresa DENTRO de una
// campaña específica (nunca se resolvió con campos sueltos en Lead —
// ver §5.2 del plan, motivo: historial de múltiples campañas por empresa).
model Campaign {
  id                   String            @id @default(cuid())
  tenantId             String
  name                 String // "Construction Illinois"
  status               CampaignStatus    @default(DRAFT)
  industryId           String?
  industry             Industry?         @relation(fields: [industryId], references: [id])
  state                String? // mismo campo promovido que Company.state
  city                 String?
  minCompanySize       CompanySize?
  maxCompanySize       CompanySize?
  targetCategoryIds    Json              @default("[]") // JobCategory ids — lista simple, sin M:N nueva
  minScore             Float? // filtro sobre Company.commercialScore
  priority             RiskLevel         @default(MEDIUM) // reutiliza el enum ya existente (Lead.priority)
  createdByAgentTaskId String? // Campaign Agent, si la creó la IA — null si la creó un humano
  companies            CampaignCompany[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([tenantId, status])
}

model CampaignCompany {
  id                   String                @id @default(cuid())
  tenantId             String
  campaignId           String
  campaign             Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id])
  status               CampaignCompanyStatus @default(TARGETED)
  lastIntent           ConversationIntent?
  lastIntentAt         DateTime?
  createdByAgentTaskId String? // qué AgentTask (selectTargetCompanies) la agregó
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([campaignId, companyId])
  @@index([tenantId, status])
}

// ================= TALENTO =================

model JobCategory {
  id                     String        @id @default(cuid())
  tenantId               String? // null = global (seed)
  name                   String // "Journeyman Electrician", "Forklift Operator"...
  industryId             String?
  industry               Industry?     @relation(fields: [industryId], references: [id])
  requiredCertifications Json          @default("[]") // keys de DocumentType
  candidates             Candidate[]
  jobOrders              JobOrder[]
  opportunities          Opportunity[] // F1
  possibleForCompanies   Company[]     @relation("CompanyPossibleCategories") // F1

  @@index([tenantId])
}

model Candidate {
  id              String          @id @default(cuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  languages       String[]        @default([]) // ["es", "en"]
  city            String?
  state           String?
  zip             String?
  categories      JobCategory[]
  yearsExperience Int?
  resumeUrl       String?
  aiSummary       String?
  aiScore         Float?
  status          CandidateStatus @default(NEW)
  source          String?
  smsOptIn        Boolean         @default(false) // TCPA desde F0
  documents       Document[]
  worker          Worker?
  qualifications  CandidateQualification[]
  matches         CandidateMatch[]
  shortlistEntries CandidateShortlistEntry[]
  screeningPlans  ScreeningPlan[]
  // F5.2: referencia de actor sin @relation — mismo patrón que
  // JobOrder.createdById (F5.1, decisión #2 del header del schema). Se
  // completa desde el contexto de tenancy en el service, nunca desde el
  // body del cliente. Nullable, sin backfill: los candidatos existentes
  // (seed de F0) no tienen un creador humano real. AuditLog sigue siendo
  // la fuente de auditoría detallada; este campo es solo para mostrar
  // "creado por" en la UI sin una consulta adicional.
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, state, city])
}

model Worker {
  id               String            @id @default(cuid())
  tenantId         String
  candidateId      String            @unique
  candidate        Candidate         @relation(fields: [candidateId], references: [id])
  employmentType   EmploymentType    @default(W2)
  defaultPayRate   Decimal           @db.Decimal(10, 2)
  status           WorkerStatus      @default(AVAILABLE)
  complianceStatus ComplianceStatus  @default(PENDING)
  hiredAt          DateTime?
  documents        Document[]
  assignments      Assignment[]
  payrollItems     PayrollItem[]
  alerts           ComplianceAlert[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, complianceStatus])
}

// ================= VACANTES Y OPERACIONES =================

model JobOrder {
  id               String            @id @default(cuid())
  tenantId         String
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id])
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id])
  categoryId       String
  category         JobCategory       @relation(fields: [categoryId], references: [id])
  title            String
  description      String? // F5.1: descripción operativa general — distinta de scheduleNotes (específico de horario)
  workersNeeded    Int
  workersFilled    Int               @default(0)
  billRate         Decimal           @db.Decimal(10, 2)
  payRate          Decimal           @db.Decimal(10, 2)
  location         Json? // { city, state, address }
  shiftType        ShiftType         @default(DAY)
  scheduleNotes    String?
  startDate        DateTime
  endDate          DateTime?
  status           JobOrderStatus    @default(DRAFT) // F5.1: arranca en DRAFT, nunca directo en OPEN
  requirements     Json              @default("[]") // keys de DocumentType requeridos
  urgency          RiskLevel         @default(MEDIUM)
  // F5.1: referencia de actor sin @relation — mismo patrón que
  // PayrollRun.createdById (decisión #2 del header del schema). Se
  // completa desde el contexto de tenancy en el service, nunca desde el
  // body del cliente. Nullable para compatibilidad con registros ya
  // existentes (seed de F0), que no tienen un creador humano real.
  createdById      String?
  assignments      Assignment[]
  pricingScenarios PricingScenario[]
  qualifications   CandidateQualification[]
  matches          CandidateMatch[]
  shortlistEntries CandidateShortlistEntry[]
  screeningPlans   ScreeningPlan[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([companyId])
}

// F8.5: estado de calificación persistido, con razones auditables, de UN
// Candidate contra UN JobOrder específico -- resultado de aplicar
// `recruiting-intelligence/qualification-rules.ts` (F8.2) y derivar el
// estado de 4 valores. Un registro por par (upsert en cada
// (re)evaluación) -- el historial de cambios de estado vive en AuditLog
// (mismo patrón que Candidate.status), esta tabla es el estado ACTUAL.
model CandidateQualification {
  id                String              @id @default(cuid())
  tenantId          String
  candidateId       String
  candidate         Candidate           @relation(fields: [candidateId], references: [id])
  jobOrderId        String
  jobOrder          JobOrder            @relation(fields: [jobOrderId], references: [id])
  status            QualificationStatus
  reasons           String[]            @default([])
  hardDisqualifiers String[]            @default([])
  rulesVersion      Int
  // F8.5: quién disparó la evaluación -- del contexto de tenancy, nunca
  // del body (mismo patrón que Candidate.createdById, F5.2).
  evaluatedById     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([tenantId, status])
}

// F8.6: nivel de confianza del match -- basado en cuánta información
// clave falta del perfil del candidato (missingData), no en el score en
// sí. Enum separado de RiskLevel (ya existe, pero se usa para otro
// dominio -- urgencia de JobOrder) para no acoplar conceptos distintos.
enum MatchConfidence {
  HIGH
  MEDIUM
  LOW
}

// F8.6: resultado ACTUAL de matching/ranking de UN Candidate contra UN
// JobOrder (etapa de reclutamiento) -- mismo patrón que
// CandidateQualification (un registro por par, upsert en cada
// recálculo, historial vía AuditLog). `softPreferences` es Json porque
// es un arreglo de factores heterogéneo (key/label/maxWeight/score/
// evidence) -- mismo criterio ya usado para JobOrder.requirements y
// AgentTask.output. `rank` es null para candidatos NOT_QUALIFIED
// (excluidos, nunca aparecen en un ranking).
model CandidateMatch {
  id                  String              @id @default(cuid())
  tenantId            String
  candidateId         String
  candidate           Candidate           @relation(fields: [candidateId], references: [id])
  jobOrderId          String
  jobOrder            JobOrder            @relation(fields: [jobOrderId], references: [id])
  qualificationStatus QualificationStatus
  recommendable       Boolean
  needsReview         Boolean
  hardConstraints     String[]            @default([])
  softPreferences     Json
  score               Float
  normalizedScore     Float
  rank                Int?
  explanation         String
  confidence          MatchConfidence
  missingData         String[]            @default([])
  risks               String[]            @default([])
  evidence            String[]            @default([])
  rulesVersion        Int
  calculatedAt        DateTime
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([tenantId, jobOrderId, rank])
}

// F8.7: estado de revisión de una entrada de shortlist -- `REMOVED`
// nunca es un rechazo definitivo (ver comentario del modelo), siempre
// puede reabrirse a `DRAFT`.
enum ShortlistReviewStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  HOLD
  REMOVED
}

// F8.7: Candidate Shortlist -- lista revisable de candidatos para UN
// JobOrder, construida a partir del ranking YA calculado por F8.6
// (`CandidateMatch`). Un registro por par (candidateId, jobOrderId),
// mismo patrón de upsert que CandidateQualification/CandidateMatch.
// `rank/score/qualificationStatus/confidence/reasons/gaps/risks` son un
// SNAPSHOT del momento en que se generó/actualizó la shortlist (no un
// join en vivo) -- se refresca explícitamente al regenerar, nunca
// automáticamente. Nunca contacta a nadie, nunca cambia
// `Candidate.status`; `REMOVED` es reversible, no un rechazo permanente.
model CandidateShortlistEntry {
  id                  String                @id @default(cuid())
  tenantId            String
  candidateId         String
  candidate           Candidate             @relation(fields: [candidateId], references: [id])
  jobOrderId          String
  jobOrder            JobOrder              @relation(fields: [jobOrderId], references: [id])
  rank                Int
  score               Float
  normalizedScore     Float
  qualificationStatus QualificationStatus
  confidence          MatchConfidence
  reasons             String[]              @default([])
  gaps                String[]              @default([])
  risks               String[]              @default([])
  reviewStatus        ShortlistReviewStatus @default(DRAFT)
  // F8.7: quién generó/agregó la entrada -- del contexto de tenancy,
  // nunca del body (mismo patrón que Candidate.createdById, F5.2).
  addedById           String?
  addedAt             DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([tenantId, jobOrderId, rank])
}

// F8.8: Screening Intelligence -- plan de preguntas de screening
// persistido para UN Candidate contra UN JobOrder. `questions` es Json
// (arreglo heterogéneo id/question/rationale/expectedEvidence, mismo
// criterio que `CandidateMatch.softPreferences`). NUNCA contiene
// respuestas (el screening real no ocurre acá, solo se prepara el
// plan) ni un veredicto de aprobación/rechazo -- eso es responsabilidad
// humana. Un registro por par, upsert en cada regeneración, historial
// vía AuditLog.
model ScreeningPlan {
  id                  String   @id @default(cuid())
  tenantId            String
  candidateId         String
  candidate           Candidate @relation(fields: [candidateId], references: [id])
  jobOrderId          String
  jobOrder            JobOrder  @relation(fields: [jobOrderId], references: [id])
  questions           Json
  allowedDisqualifiers String[] @default([])
  manualReviewFlags   String[] @default([])
  missingInformation  String[] @default([])
  riskFlags           String[] @default([])
  rulesVersion        Int
  calculatedAt        DateTime
  // F8.8: quién generó el plan -- del contexto de tenancy, nunca del
  // body (mismo patrón que Candidate.createdById, F5.2).
  generatedById       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([candidateId, jobOrderId])
  @@index([tenantId, jobOrderId])
}

model Project {
  id                  String        @id @default(cuid())
  tenantId            String
  companyId           String
  company             Company       @relation(fields: [companyId], references: [id])
  name                String
  location            Json?
  status              ProjectStatus @default(PLANNED)
  supervisorContactId String?
  jobOrders           JobOrder[]
  assignments         Assignment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([tenantId, status])
}

model Assignment {
  id           String           @id @default(cuid())
  tenantId     String
  workerId     String
  worker       Worker           @relation(fields: [workerId], references: [id])
  jobOrderId   String
  jobOrder     JobOrder         @relation(fields: [jobOrderId], references: [id])
  projectId    String?
  project      Project?         @relation(fields: [projectId], references: [id])
  payRate      Decimal          @db.Decimal(10, 2) // snapshot al asignar
  billRate     Decimal          @db.Decimal(10, 2) // snapshot al asignar
  startDate    DateTime
  endDate      DateTime?
  status       AssignmentStatus @default(SCHEDULED)
  shifts       Shift[]
  timeEntries  TimeEntry[]
  payrollItems PayrollItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId, workerId, status])
  @@index([tenantId, jobOrderId])
}

model Shift {
  id           String     @id @default(cuid())
  tenantId     String
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  startTime    String // "22:00"
  endTime      String // "06:00"
  breakMinutes Int        @default(0)

  @@index([tenantId, date])
}

model TimeEntry {
  id            String          @id @default(cuid())
  tenantId      String
  assignmentId  String
  assignment    Assignment      @relation(fields: [assignmentId], references: [id])
  date          DateTime        @db.Date
  regularHours  Decimal         @default(0) @db.Decimal(5, 2)
  overtimeHours Decimal         @default(0) @db.Decimal(5, 2)
  doubleHours   Decimal         @default(0) @db.Decimal(5, 2)
  perDiem       Decimal?        @db.Decimal(8, 2)
  bonus         Decimal?        @db.Decimal(8, 2)
  status        TimeEntryStatus @default(PENDING)
  source        TimeEntrySource @default(MANUAL)
  approvedById  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([assignmentId, date])
  @@index([tenantId, status])
  @@index([tenantId, date])
}

// ================= COMPLIANCE =================

model DocumentType {
  id                 String     @id @default(cuid())
  tenantId           String? // null = global (seed: I-9, W-4, OSHA 10...)
  key                String // "i9", "w4", "osha10", "forklift_cert", "drug_test", "background_check"
  name               String
  category           String // "identity" | "tax" | "safety" | "certification" | "screening"
  requiresExpiration Boolean    @default(false)
  appliesTo          Json       @default("{}") // reglas por industria/categoría
  documents          Document[]

  @@unique([tenantId, key])
}

model Document {
  id              String            @id @default(cuid())
  tenantId        String
  documentTypeId  String
  documentType    DocumentType      @relation(fields: [documentTypeId], references: [id])
  candidateId     String?
  candidate       Candidate?        @relation(fields: [candidateId], references: [id])
  workerId        String?
  worker          Worker?           @relation(fields: [workerId], references: [id])
  fileUrl         String?
  issuedDate      DateTime?
  expirationDate  DateTime?
  status          DocumentStatus    @default(PENDING_REVIEW)
  verifiedById    String?
  verifiedByAgent Boolean           @default(false)
  aiExtraction    Json?
  rejectionReason String?
  alerts          ComplianceAlert[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expirationDate])
}

model ComplianceAlert {
  id           String              @id @default(cuid())
  tenantId     String
  workerId     String?
  worker       Worker?             @relation(fields: [workerId], references: [id])
  documentId   String?
  document     Document?           @relation(fields: [documentId], references: [id])
  type         ComplianceAlertType
  severity     Severity            @default(MEDIUM)
  message      String
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime            @default(now())

  @@index([tenantId, resolvedAt])
}

// ================= PAYROLL Y FACTURACIÓN =================

model PayrollRun {
  id           String           @id @default(cuid())
  tenantId     String
  periodStart  DateTime         @db.Date
  periodEnd    DateTime         @db.Date
  status       PayrollRunStatus @default(DRAFT)
  totalGross   Decimal          @default(0) @db.Decimal(12, 2)
  totalBill    Decimal          @default(0) @db.Decimal(12, 2)
  totalMargin  Decimal          @default(0) @db.Decimal(12, 2)
  approvedById String?
  createdById  String?
  items        PayrollItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId, status])
}

model PayrollItem {
  id           String     @id @default(cuid())
  tenantId     String
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  workerId     String
  worker       Worker     @relation(fields: [workerId], references: [id])
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  regularHours Decimal    @db.Decimal(6, 2)
  otHours      Decimal    @default(0) @db.Decimal(6, 2)
  regularPay   Decimal    @db.Decimal(10, 2)
  otPay        Decimal    @default(0) @db.Decimal(10, 2)
  perDiem      Decimal    @default(0) @db.Decimal(10, 2)
  bonus        Decimal    @default(0) @db.Decimal(10, 2)
  grossPay     Decimal    @db.Decimal(10, 2)
  billAmount   Decimal    @db.Decimal(10, 2)
  margin       Decimal    @db.Decimal(10, 2)
  // F5.8: evita doble facturación — una vez que este billAmount ya se
  // volcó a una InvoiceLine, queda marcado y una nueva generación de
  // Invoice para el mismo período/empresa no debe volver a incluirlo.
  // Mismo patrón que TimeEntryStatus.LOCKED (flag de "ya consumido"),
  // no una relación bidireccional, para no romper el modelo actual.
  invoiced     Boolean    @default(false)

  @@index([tenantId])
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  number      String
  periodStart DateTime      @db.Date
  periodEnd   DateTime      @db.Date
  subtotal    Decimal       @db.Decimal(12, 2)
  total       Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime?
  pdfUrl      String?
  lines       InvoiceLine[]
  // F5.8: Opción B aprobada (plan §10.1) — historial completo de pagos
  // parciales vía un modelo propio, en vez de paidAmount/paidAt planos en
  // Invoice. balance siempre se deriva (total - sum(Payment.amount)),
  // nunca se guarda una columna que pueda desincronizarse (mismo
  // principio ya aplicado en todo el proyecto desde F1).
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
}

// F5.8 (plan §10.1, Opción B aprobada por el PO): un Invoice puede
// cobrarse en varias cuotas — cada Payment es una fila real, nunca se
// sobreescribe. method es texto libre (no un enum cerrado): no se pidió
// una lista fija de métodos de pago, y el proyecto ya prefiere data
// sobre código para catálogos abiertos (mismo criterio D13).
model Payment {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @default(now())
  method    String?
  reference String?
  createdAt DateTime @default(now())

  @@index([tenantId, invoiceId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(8, 2) // horas
  rate        Decimal @db.Decimal(10, 2)
  amount      Decimal @db.Decimal(12, 2)
}

model Contract {
  id             String         @id @default(cuid())
  tenantId       String
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  fileUrl        String?
  signedDate     DateTime?
  expirationDate DateTime?
  markupPercent  Decimal?       @db.Decimal(5, 2)
  terms          Json           @default("{}")
  status         ContractStatus @default(DRAFT)
  createdAt      DateTime       @default(now())

  @@index([tenantId, status])
}

// ================= PRICING INTELLIGENCE =================

model LaborBurdenConfig {
  id                String   @id @default(cuid())
  tenantId          String
  state             String // "IL", "IN"...
  jobCategoryId     String? // null = default del estado
  workersCompRate   Decimal  @db.Decimal(5, 2) // % sobre payroll, por class code
  ficaRate          Decimal  @default(7.65) @db.Decimal(5, 2)
  futaRate          Decimal  @default(0.60) @db.Decimal(5, 2)
  sutaRate          Decimal  @db.Decimal(5, 2)
  liabilityRate     Decimal? @db.Decimal(5, 2)
  otherCostsPerHour Decimal? @db.Decimal(8, 2)
  effectiveDate     DateTime @db.Date

  @@index([tenantId, state])
}

model RateBenchmark {
  id            String          @id @default(cuid())
  tenantId      String? // null = benchmark global compartido (BLS)
  source        BenchmarkSource
  jobCategoryId String
  city          String?
  state         String
  shiftType     ShiftType?
  payRateP25    Decimal         @db.Decimal(10, 2)
  payRateP50    Decimal         @db.Decimal(10, 2)
  payRateP75    Decimal         @db.Decimal(10, 2)
  billRateP50   Decimal?        @db.Decimal(10, 2)
  sampleSize    Int?
  capturedAt    DateTime

  @@index([jobCategoryId, state, shiftType])
}

model PricingScenario {
  id                   String                @id @default(cuid())
  tenantId             String
  jobOrderId           String?
  jobOrder             JobOrder?             @relation(fields: [jobOrderId], references: [id])
  opportunityId        String?
  opportunity          Opportunity?          @relation(fields: [opportunityId], references: [id])
  inputs               Json // { volumen, urgencia, turno, dificultad, duración }
  recommendedPayMin    Decimal               @db.Decimal(10, 2)
  recommendedPayMax    Decimal               @db.Decimal(10, 2)
  recommendedBillMin   Decimal               @db.Decimal(10, 2)
  recommendedBillMax   Decimal               @db.Decimal(10, 2)
  grossMarginPerHour   Decimal               @db.Decimal(10, 2)
  netMarginPerHour     Decimal?              @db.Decimal(10, 2)
  hiringRisk           HiringRisk            @default(MEDIUM)
  dataConfidence       RiskLevel             @default(MEDIUM) // según sampleSize/antigüedad
  rationale            String
  status               PricingScenarioStatus @default(DRAFT)
  decidedById          String?
  createdByAgentTaskId String?
  createdAt            DateTime              @default(now())

  @@index([tenantId, status])
}

// ================= AGENTES IA =================

model AgentDefinition {
  id                   String          @id @default(cuid())
  key                  String          @unique // "recruiter", "compliance", "assistant", "pricing", "sales", "operations", "payroll", "marketing", "ceo", "admin"
  name                 String
  description          String
  systemPromptTemplate String          @default("") // vacío en F0, se llena en F3
  availableTools       Json            @default("[]")
  defaultAutonomy      AutonomyLevel   @default(ASSISTED)
  instances            AgentInstance[]
}

model AgentInstance {
  id            String          @id @default(cuid())
  tenantId      String
  definitionId  String
  definition    AgentDefinition @relation(fields: [definitionId], references: [id])
  autonomyLevel AutonomyLevel   @default(ASSISTED)
  config        Json            @default("{}")
  isActive      Boolean         @default(true)
  metrics       Json            @default("{}") // KPIs: tareas, precisión, costo mensual
  tasks         AgentTask[]
  memories      AgentMemory[]
  createdAt     DateTime        @default(now())

  @@unique([tenantId, definitionId])
  @@index([tenantId])
}

model AgentTask {
  id              String            @id @default(cuid())
  tenantId        String
  agentInstanceId String
  agentInstance   AgentInstance     @relation(fields: [agentInstanceId], references: [id])
  type            String // "screen_candidate", "verify_document", "recommend_rates"...
  input           Json
  output          Json?
  status          AgentTaskStatus   @default(QUEUED)
  triggeredBy     TaskTrigger
  parentTaskId    String?
  parentTask      AgentTask?        @relation("TaskChain", fields: [parentTaskId], references: [id])
  childTasks      AgentTask[]       @relation("TaskChain")
  errorMessage    String?
  tokensUsed      Int?
  costUsd         Decimal?          @db.Decimal(10, 4)
  approvals       ApprovalRequest[]
  createdAt       DateTime          @default(now())
  completedAt     DateTime?

  @@index([tenantId, status])
  @@index([agentInstanceId, createdAt])
}

model AgentMemory {
  id              String        @id @default(cuid())
  tenantId        String
  agentInstanceId String
  agentInstance   AgentInstance @relation(fields: [agentInstanceId], references: [id], onDelete: Cascade)
  scope           MemoryScope   @default(GLOBAL)
  entityType      String?
  entityId        String?
  content         String
  // embedding vector — pgvector sigue diferido (decisión #5). F3 usa
  // AgentMemory sin embeddings, con consultas estructuradas por
  // entityType/entityId/scope (ver F3_PROSPECTING_ENGINE_PLAN.md §7).
  importance      Float         @default(0.5)
  lastAccessedAt  DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@index([tenantId, agentInstanceId])
  @@index([tenantId, entityType, entityId])
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  tenantId       String
  agentTaskId    String
  agentTask      AgentTask      @relation(fields: [agentTaskId], references: [id])
  summary        String
  proposedAction Json
  riskLevel      RiskLevel      @default(MEDIUM)
  status         ApprovalStatus @default(PENDING)
  decidedById    String?
  decidedAt      DateTime?
  decisionNote   String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  @@index([tenantId, status])
}

// ================= AUDITORÍA, EVENTOS, NOTIFICACIONES =================

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String
  actorType  ActorType
  actorId    String // User.id o AgentInstance.id o "system"
  action     String // "candidate.created", "payroll.approved"...
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model DomainEvent {
  id          String    @id @default(cuid())
  tenantId    String
  type        String // "jobOrder.created", "document.expired"...
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([processedAt])
  @@index([tenantId, type])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId, userId, readAt])
}
