{
  "name": "@ai-staffing-os/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "dotenv -e ../../.env -- tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "dotenv -e ../../.env -- node --import tsx --test --test-concurrency=1 src/**/*.test.ts"
  },
  "dependencies": {
    "@ai-staffing-os/agents": "workspace:*",
    "@ai-staffing-os/db": "workspace:*",
    "@ai-staffing-os/shared": "workspace:*",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "robots-parser": "^3.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.11.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
